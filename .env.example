# LLM API (used by backend for reports, resume parsing, crawler agent)
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Sandbox image name (must be built first)
SANDBOX_IMAGE=crawler-sandbox

# Frontend API URL (as seen from the browser)
# For local deployment: http://localhost:8000
# For remote server: http://<your-server-ip>:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
